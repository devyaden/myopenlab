generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Existing models remain the same...
model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  auth_id    String   @unique
  name       String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  folders    Folder[]
  canvases   Canvas[]

  @@map("users")
}

model Folder {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  canvases        Canvas[]
  nodeConnections NodeConnection[]

  @@index([user_id])
  @@map("folders")
}

model Canvas {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  last_edited  DateTime @default(now())
  flow_data    Json // nodes, edges and viewport
  is_published Boolean  @default(false)

  user      User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id   Int
  folder    Folder @relation(fields: [folder_id], references: [id], onDelete: Cascade)
  folder_id Int

  sourceNodes NodeConnection[] @relation("SourceCanvas")
  targetNodes NodeConnection[] @relation("TargetCanvas")

  // New relations for custom columns
  customColumns  CustomColumn[]
  nodeCustomData NodeCustomData[]

  referencedBy CustomColumn[] @relation("RelatedCanvas")

  @@index([user_id])
  @@index([folder_id])
  @@map("canvas")
}

model NodeConnection {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  source_node_id String
  target_node_id String

  label    String?
  metadata Json?

  source_canvas    Canvas @relation("SourceCanvas", fields: [source_canvas_id], references: [id], onDelete: Cascade)
  source_canvas_id Int
  target_canvas    Canvas @relation("TargetCanvas", fields: [target_canvas_id], references: [id], onDelete: Cascade)
  target_canvas_id Int

  folder    Folder @relation(fields: [folder_id], references: [id], onDelete: Cascade)
  folder_id Int

  @@unique([source_canvas_id, target_canvas_id, source_node_id, target_node_id])
  @@index([source_canvas_id])
  @@index([target_canvas_id])
  @@index([folder_id])
  @@map("node_connections")
}

// New model for custom columns
model CustomColumn {
  id         Int      @id @default(autoincrement())
  name       String
  type       String // 'text', 'number', 'date', 'select', etc.
  options    Json? // For select type, store options as array
  required   Boolean  @default(false)
  validation Json? // Store validation rules (min, max, pattern, etc.)
  order      Int // To maintain column order in the UI
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  // Relationship to Canvas
  canvas    Canvas @relation(fields: [canvas_id], references: [id], onDelete: Cascade)
  canvas_id Int

  relatedCanvas     Canvas? @relation("RelatedCanvas", fields: [related_canvas_id], references: [id])
  related_canvas_id Int?

  related_column_id Int? // For select type, store the related column ID

  // Relationship to values
  values NodeCustomData[]

  @@index([canvas_id])
  @@map("custom_columns")
}

// New model for storing custom column values for each node
model NodeCustomData {
  id         Int      @id @default(autoincrement())
  node_id    String // ReactFlow node ID
  value      Json // Store the actual value
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  // Relationships
  canvas       Canvas       @relation(fields: [canvas_id], references: [id], onDelete: Cascade)
  canvas_id    Int
  customColumn CustomColumn @relation(fields: [column_id], references: [id], onDelete: Cascade)
  column_id    Int

  @@unique([node_id, column_id]) // Each node can have only one value per column
  @@index([canvas_id])
  @@index([column_id])
  @@map("node_custom_data")
}
