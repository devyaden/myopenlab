generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email                String?            @unique
  name                 String?
  id                   String             @id @db.Uuid
  role                 String             @default("user")
  onboarding_completed Boolean            @default(false)
  has_seen_onboarding  Boolean            @default(false)
  onboarding_data      Json?              @default("{}")
  avatar_url           String?
  company_email        String?
  company_name         String?
  company_sector       String?
  company_size         String?
  user_position        String?
  username             String?            @unique
  created_at           DateTime           @default(now())
  updated_at           DateTime           @default(now()) @updatedAt
  canvases             Canvas[]
  shared_canvases      CanvasShare[]
  folders              Folder[]
  notifications        String[]
  subscriptions        UserSubscription[]

  @@map("user")
}

model Folder {
  name       String
  id         String   @id @default(uuid()) @db.Uuid
  created_at DateTime @default(now())
  parent_id  String?  @db.Uuid
  updated_at DateTime @default(now()) @updatedAt
  user_id    String   @db.Uuid
  canvases   Canvas[]
  parent     Folder?  @relation("FolderHierarchy", fields: [parent_id], references: [id])
  children   Folder[] @relation("FolderHierarchy")
  user       User     @relation(fields: [user_id], references: [id])

  @@map("folder")
}

model Canvas {
  name            String
  description     String?
  id              String             @id @default(uuid()) @db.Uuid
  created_at      DateTime           @default(now())
  folder_id       String?            @db.Uuid
  updated_at      DateTime           @default(now()) @updatedAt
  user_id         String             @db.Uuid
  code            String? // Phase 2: human-readable code (e.g. "HR-01"), unique per user
  directory_kind  String? // Phase 5d: 'person' | 'role' marks a Table canvas as a people/role directory (NULL = normal canvas)
  folder          Folder?            @relation(fields: [folder_id], references: [id])
  user            User               @relation(fields: [user_id], references: [id])
  data            CanvasData?
  document_data   DocumentData?
  history         CanvasHistory[]
  settings        CanvasSettings?
  shares          CanvasShare[]
  visibility      String             @default("private")
  columns         ColumnDefinition[]
  related_columns ColumnDefinition[] @relation("RelatedColumn")
  canvas_type     String             @default("hybrid")
  references_from Reference[]        @relation("ReferenceFromCanvas")
  references_to   Reference[]        @relation("ReferenceToCanvas")

  @@unique([user_id, code])
  @@map("canvas")
}

// Phase 2: lightweight typed references between artifacts (the cross-reference
// spine). `from`/`to` point at a canvas (+ optional node id within it) or are
// resolved by a human code. Powers backlinks + dangling-ref integrity checks.
model Reference {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  from_canvas String   @db.Uuid
  from_node   String?
  to_canvas   String?  @db.Uuid
  to_node     String?
  to_code     String?
  type        String // process-step | template | policy | standard | checklist | authority | person | role | depends-on
  created_at  DateTime @default(now())
  fromCanvas  Canvas   @relation("ReferenceFromCanvas", fields: [from_canvas], references: [id], onDelete: Cascade)
  toCanvas    Canvas?  @relation("ReferenceToCanvas", fields: [to_canvas], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([from_canvas])
  @@index([to_canvas])
  @@index([to_code])
  @@map("reference")
}

model CanvasData {
  nodes      Json
  edges      Json
  styles     Json
  version    Int      @default(1)
  canvas_id  String   @unique @db.Uuid
  updated_at DateTime @default(now()) @updatedAt
  canvas     Canvas   @relation(fields: [canvas_id], references: [id])

  @@map("canvas_data")
}

model CanvasHistory {
  data       Json
  version    Int
  id         String   @id @default(uuid()) @db.Uuid
  canvas_id  String   @db.Uuid
  created_at DateTime @default(now())
  canvas     Canvas   @relation(fields: [canvas_id], references: [id])

  @@map("canvas_history")
}

model ColumnDefinition {
  id                   String             @id @default(uuid()) @db.Uuid
  title                String
  type                 String
  options              Json?
  required             Boolean            @default(false)
  order                Int
  data_key             String?
  canvas_id            String             @db.Uuid
  created_at           DateTime           @default(now())
  updated_at           DateTime           @default(now()) @updatedAt
  related_canvas_id    String?            @db.Uuid
  relation_row_ids     String[]
  rollup_column_id     String?            @db.Uuid
  canvas               Canvas             @relation(fields: [canvas_id], references: [id])
  related_canvas       Canvas?            @relation("RelatedColumn", fields: [related_canvas_id], references: [id])
  rollup_target_column ColumnDefinition?  @relation("RollupReference", fields: [rollup_column_id], references: [id])
  referencing_rollups  ColumnDefinition[] @relation("RollupReference")

  @@map("column_definition")
}

model CanvasSettings {
  id               String   @id @default(uuid()) @db.Uuid
  theme            String?
  canvas_id        String   @unique @db.Uuid
  grid_size        Int      @default(15)
  show_grid        Boolean  @default(true)
  show_rulers      Boolean  @default(false)
  snap_to_grid     Boolean  @default(true)
  table_settings   Json?
  background_color String?  @default("#ffffff")
  updated_at       DateTime @default(now()) @updatedAt
  canvas           Canvas   @relation(fields: [canvas_id], references: [id])

  @@map("canvas_settings")
}

model CanvasShare {
  role       String
  id         String   @id @default(uuid()) @db.Uuid
  canvas_id  String   @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  user_id    String   @db.Uuid
  canvas     Canvas   @relation(fields: [canvas_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([canvas_id, user_id])
  @@map("canvas_share")
}

model DocumentData {
  lexical_state Json // Stores the Lexical editor state
  version       Int      @default(1)
  canvas_id     String   @unique @db.Uuid
  updated_at    DateTime @default(now()) @updatedAt
  canvas        Canvas   @relation(fields: [canvas_id], references: [id], onDelete: Cascade)

  @@map("document_data")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  title              String
  // Phase F2: a stable plan key (e.g. "free", "pro_monthly", "pro_yearly",
  // "business_yearly") that PLAN_LIMITS maps to a limits profile. Set at checkout;
  // null/unknown falls back to the free profile.
  plan_key           String?
  description        String?
  price              Float
  duration           Int // Duration in days
  features           String[]
  active             Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @default(now()) @updatedAt
  user_subscriptions UserSubscription[]
  promo_codes        PromoCode[]

  @@map("subscription")
}

model PromoCode {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  code               String             @unique
  subscription_id    String?            @db.Uuid
  stripe_price_id    String?
  duration_months    Int?
  expiry_date        DateTime
  is_domain_specific Boolean            @default(false)
  allowed_domains    String[]
  allowed_emails     String[]
  max_uses           Int? // null means unlimited
  uses_per_user      Int                @default(1)
  active             Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @default(now()) @updatedAt
  subscription       Subscription?      @relation(fields: [subscription_id], references: [id])
  user_subscriptions UserSubscription[]

  @@map("promo_code")
}

model UserSubscription {
  id                     String       @id @default(uuid()) @db.Uuid
  user_id                String       @db.Uuid
  subscription_id        String       @db.Uuid
  promo_code_id          String?      @db.Uuid
  stripe_subscription_id String?      @unique // Stripe subscription ID for validation
  stripe_customer_id     String? // Stripe customer ID
  start_date             DateTime     @default(now())
  end_date               DateTime
  is_active              Boolean      @default(true)
  created_at             DateTime     @default(now())
  updated_at             DateTime     @default(now()) @updatedAt
  user                   User         @relation(fields: [user_id], references: [id])
  subscription           Subscription @relation(fields: [subscription_id], references: [id])
  promo_code             PromoCode?   @relation(fields: [promo_code_id], references: [id])

  @@map("user_subscription")
}

model AiUsage {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  month      Int // 1-12
  year       Int
  count      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([user_id, month, year])
  @@map("ai_usage")
}

model AgentConversation {
  id          String            @id @default(uuid()) @db.Uuid
  user_id     String            @db.Uuid
  canvas_id   String?           @db.Uuid // optional: the playbook in focus when started
  title       String?
  // Phase F4: auto-compaction. Once the live context nears the plan's cap, the
  // oldest turns up to this ordinal are replaced by `summary` on replay.
  compacted_through_ordinal Int?
  summary                   String?
  created_at  DateTime          @default(now())
  updated_at  DateTime          @default(now()) @updatedAt
  messages    AgentMessage[]
  attachments AgentAttachment[]
  proposals   AgentProposal[]

  @@index([user_id, updated_at])
  @@map("agent_conversation")
}

model AgentMessage {
  id              String            @id @default(uuid()) @db.Uuid
  conversation_id String            @db.Uuid
  role            String // "user" | "assistant"
  content         Json // array of Anthropic content blocks (text/tool_use/tool_result/thinking)
  // Phase F1: per-turn token usage (set on the assistant turn). input_tokens on the
  // latest assistant message ≈ the conversation's current context size.
  input_tokens      Int?
  output_tokens     Int?
  cache_read_tokens Int?
  billable_tokens   Int?
  created_at      DateTime          @default(now())
  conversation    AgentConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
  @@map("agent_message")
}

// Phase F2b: daily token spend per user. Monthly usage = SUM over the month's rows.
model AiTokenUsage {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           String   @db.Uuid
  day               String // YYYY-MM-DD (UTC)
  input_tokens      Int      @default(0)
  output_tokens     Int      @default(0)
  cache_read_tokens Int      @default(0)
  billable_tokens   Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  @@unique([user_id, day])
  @@index([user_id])
  @@map("ai_token_usage")
}

model AgentAttachment {
  id              String            @id @default(uuid()) @db.Uuid
  conversation_id String            @db.Uuid
  user_id         String            @db.Uuid
  storage_path    String
  public_url      String
  file_name       String
  media_type      String
  kind            String // image | pdf | text | docx
  extracted_text  String?
  created_at      DateTime          @default(now())
  conversation    AgentConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@map("agent_attachment")
}

model AgentProposal {
  id                String            @id @default(uuid()) @db.Uuid
  conversation_id   String            @db.Uuid
  message_ordinal   Int? // which user turn (count of prior user turns)
  proposal_index    Int? // order within that turn (emitted order)
  proposal_json     Json // the normalized ToolProposal
  status            String            @default("pending") // pending | applied | discarded | failed
  applied_canvas_id String?           @db.Uuid
  created_at        DateTime          @default(now())
  conversation      AgentConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, message_ordinal, proposal_index])
  @@map("agent_proposal")
}
