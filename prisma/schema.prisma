generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int     @id @default(autoincrement())
  email          String  @unique
  username       String  @unique
  name           String?
  auth_id        String?
  // company details
  company_name   String?
  company_email  String?
  company_sector String?
  user_position  String?
  company_size   String?

  folders    Folder[]
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@index([email])
  @@map("users")
}

model Folder {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  canvases    Canvas[]
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  @@index([user_id])
  @@map("folders")
}

model Canvas {
  id               Int        @id @default(autoincrement())
  name             String
  description      String?
  flow_data        Json
  folder_id        Int
  folder           Folder     @relation(fields: [folder_id], references: [id], onDelete: Cascade)
  nodes            Node[]
  columns          Column[]
  rollups          Rollup[]
  source_relations Relation[] @relation("SourceCanvas")
  target_relations Relation[] @relation("TargetCanvas")
  column_order     Json?      @default("[]")
  created_at       DateTime   @default(now())
  updated_at       DateTime   @default(now()) @updatedAt

  @@index([folder_id])
  @@map("canvases")
}

model Node {
  id          Int      @id @default(autoincrement())
  canvas_id   Int
  node_id     String
  canvas      Canvas   @relation(fields: [canvas_id], references: [id], onDelete: Cascade)
  flow_data   Json
  custom_data Json
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  @@index([canvas_id])
  @@map("nodes")
}

model Column {
  id          Int        @id @default(autoincrement())
  name        String
  key         String
  canvas_id   Int
  canvas      Canvas     @relation(fields: [canvas_id], references: [id], onDelete: Cascade)
  data_type   ColumnType
  is_required Boolean    @default(false)
  validation  Json?
  order       Int        @default(0)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @default(now()) @updatedAt

  @@index([canvas_id])
  @@map("columns")
}

model Rollup {
  id               Int         @id @default(autoincrement())
  name             String
  canvas_id        Int
  canvas           Canvas      @relation(fields: [canvas_id], references: [id], onDelete: Cascade)
  relation_id      Int
  relation         Relation    @relation(fields: [relation_id], references: [id], onDelete: Cascade)
  target_column_id Int?
  target_column    String
  aggregation      RollupType?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @default(now()) @updatedAt

  @@index([canvas_id])
  @@index([relation_id])
  @@map("rollups")
}

model Relation {
  id               Int      @id @default(autoincrement())
  name             String   @default("Relation")
  source_canvas_id Int
  source_canvas    Canvas   @relation("SourceCanvas", fields: [source_canvas_id], references: [id], onDelete: Cascade)
  target_canvas_id Int
  target_canvas    Canvas   @relation("TargetCanvas", fields: [target_canvas_id], references: [id], onDelete: Cascade)
  rollups          Rollup[]
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt

  @@index([source_canvas_id])
  @@index([target_canvas_id])
  @@map("relations")
}

enum ColumnType {
  STRING
  NUMBER
  BOOLEAN
  DATE
  RELATION
  ROLLUP

  @@map("column_type")
}

enum RollupType {
  COUNT
  SUM
  AVERAGE
  MIN
  MAX

  @@map("rollup_type")
}
