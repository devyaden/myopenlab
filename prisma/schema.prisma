generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  auth_id    String   @unique
  name       String?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  folders    Folder[]
  canvases   Canvas[]

  @@map("users")
}

model Folder {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  // Relationships
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  // Folder can contain multiple canvases
  canvases Canvas[]

  // Node connections within this folder
  nodeConnections NodeConnection[]

  @@index([user_id])
  @@map("folders")
}

model Canvas {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  last_edited  DateTime @default(now())
  flow_data    Json // nodes, edges and viewport
  is_published Boolean  @default(false)

  // Relationships
  user      User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id   Int
  folder    Folder @relation(fields: [folder_id], references: [id], onDelete: Cascade)
  folder_id Int

  // Canvas linking relationships (for node connections)
  sourceNodes NodeConnection[] @relation("SourceCanvas")
  targetNodes NodeConnection[] @relation("TargetCanvas")

  @@index([user_id])
  @@index([folder_id])
  @@map("canvas")
}

model NodeConnection {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  // Node identifiers
  source_node_id String // ID of the source node (from ReactFlow)
  target_node_id String // ID of the target node (from ReactFlow)

  // Connection metadata
  label    String?
  metadata Json? // Additional connection properties

  // Relationships
  source_canvas    Canvas @relation("SourceCanvas", fields: [source_canvas_id], references: [id], onDelete: Cascade)
  source_canvas_id Int
  target_canvas    Canvas @relation("TargetCanvas", fields: [target_canvas_id], references: [id], onDelete: Cascade)
  target_canvas_id Int

  // Folder relationship to ensure connections stay within the same folder
  folder    Folder @relation(fields: [folder_id], references: [id], onDelete: Cascade)
  folder_id Int

  @@unique([source_canvas_id, target_canvas_id, source_node_id, target_node_id])
  @@index([source_canvas_id])
  @@index([target_canvas_id])
  @@index([folder_id])
  @@map("node_connections")
}
